# ──────────────────────────────────────────────
# VaultDrive — Environment Configuration
# ──────────────────────────────────────────────

# Server
PORT=3000

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/vaultdrive?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Filebase (S3-compatible object storage)
FILEBASE_ACCESS_KEY="your-filebase-access-key"
FILEBASE_SECRET_KEY="your-filebase-secret-key"
FILEBASE_BUCKET="your-filebase-bucket-name"

# Upload Configuration
CHUNK_SIZE_BYTES=5242880  # 5 MB default
